# EC2 운영 인스턴스의 ~/app/.env 로 복사 후 실 값 채워서 사용.
# 본 파일은 키 목록만 명시하며 실제 시크릿은 절대 커밋하지 않는다.

# Spring profile (staging | prod)
SPRING_PROFILES_ACTIVE=staging

# PostgreSQL
DB_URL=jdbc:postgresql://<host>:5432/pms_order
DB_USERNAME=
DB_PASSWORD=

# RabbitMQ
RABBIT_HOST=
RABBIT_PORT=5672
RABBIT_USERNAME=
RABBIT_PASSWORD=
